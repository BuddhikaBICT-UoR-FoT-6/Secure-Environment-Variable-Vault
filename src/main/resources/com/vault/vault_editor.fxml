<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    Root layout to inject into the Dashboard center.
    fx:controller binds this directly to VaultEditorController.
-->
<VBox fx:id="editorContainer" prefHeight="500.0" prefWidth="550.0" spacing="15.0" 
      xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.vault.ui.VaultEditorController">
      
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Area -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="projectTitleLabel" text="Project Secrets" textFill="#f1fa8c">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        
        <!-- Pushes the launch button to the right side -->
        <Region HBox.hgrow="ALWAYS" />
        
        <!-- The big green LAUNCH button that triggers the ProcessInjector -->
        <Button mnemonicParsing="false" styleClass="success-button" text="🚀 LAUNCH PROJECT" onAction="#handleLaunch" />
    </HBox>

    <Label text="These environment variables will be injected into memory only." textFill="#6272a4" />

    <!-- 
        The Secrets Table 
        VBox.vgrow makes it expand to fill all vertical space.
    -->
    <TableView fx:id="secretsTable" VBox.vgrow="ALWAYS" styleClass="secrets-table">
        <columns>
            <!-- fx:id tags used by the Java Controller to map to VaultEntry properties -->
            <TableColumn fx:id="keyColumn" prefWidth="250.0" text="Environment Variable Key" />
            <TableColumn fx:id="valueColumn" prefWidth="250.0" text="Encrypted Value" />
        </columns>
        <!-- Disables the extra empty column placeholder in JavaFX -->
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Footer Controls -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button mnemonicParsing="false" styleClass="primary-outline-button" text="+ Add Secret" onAction="#handleAddSecret" />
        <Button mnemonicParsing="false" styleClass="danger-outline-button" text="🗑 Delete Selected" onAction="#handleDeleteSecret" />
    </HBox>

</VBox>
