<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    Root layout is a BorderPane.
    It binds to DashboardController logic.
-->
<BorderPane fx:id="rootPane" prefHeight="600.0" prefWidth="800.0" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.vault.ui.DashboardController">

    <!-- TOP: Navigation Bar -->
    <top>
        <!-- HBox aligns elements horizontally -->
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="nav-bar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <Label text="🔒 Vault Dashboard" textFill="#bd93f9">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            
            <!-- A spacer Region to push the Lock button to the far right -->
            <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
            
            <Button mnemonicParsing="false" styleClass="danger-button" text="Lock &amp; Exit" onAction="#handleLockVault" />
        </HBox>
    </top>

    <!-- LEFT: Project Sidebar -->
    <left>
        <VBox prefWidth="250.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label text="Your Workspaces" textFill="#8be9fd">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            
            <!-- This ListView is dynamically populated with Projects by the Controller -->
            <ListView fx:id="projectListView" VBox.vgrow="ALWAYS" styleClass="project-list" />
            
            <HBox spacing="10.0">
                <Button maxWidth="Infinity" styleClass="primary-button" text="New" HBox.hgrow="ALWAYS" onAction="#handleNewProject" />
                <Button maxWidth="Infinity" styleClass="danger-outline-button" text="Delete" HBox.hgrow="ALWAYS" onAction="#handleDeleteProject" />
            </HBox>
            <Button maxWidth="Infinity" text="🔗 Link Git Repository" styleClass="button-accent" onAction="#handleLinkRepo" />
        </VBox>
    </left>

    <!-- CENTER: Main Editor Area -->
    <!-- Leave it blank! The Controller dynamically loads vault_editor.fxml into this space when a project is clicked. -->
    <center>
        <VBox alignment="CENTER" styleClass="empty-state">
            <Label text="Select or create a workspace to manage variables." textFill="#6272a4" />
        </VBox>
    </center>

</BorderPane>
