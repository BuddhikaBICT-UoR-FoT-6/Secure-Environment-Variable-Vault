<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- 
    The root VBox container. 
    fx:controller binds this UI strictly to the MasterPasswordController class. 
-->
<VBox fx:id="mainContainer" 
      alignment="CENTER" 
      spacing="20.0" 
      xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.vault.ui.MasterPasswordController">
      
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- Header / Logo Area -->
    <ImageView fx:id="logoImageView" fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
        <Image url="@logo.png" />
    </ImageView>

    <Label text="🔒 LOCAL VAULT" textFill="#bd93f9">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Enter master password to unlock" textFill="#f8f8f2" />

    <!-- 
        The Password field. 
    -->
    <PasswordField fx:id="passwordField" 
                   promptText="Master Password" 
                   onAction="#handleUnlock"
                   prefHeight="40.0" />

    <!-- 
        The Unlock Button.
    -->
    <Button mnemonicParsing="false" 
            onAction="#handleUnlock" 
            prefHeight="40.0" 
            prefWidth="Infinity" 
            text="UNLOCK VAULT" 
            styleClass="primary-button" />

    <!-- 
        Error Label.
    -->
    <Label fx:id="errorLabel" 
           text="Decryption failed. Wrong password?" 
           textFill="#ff5555" 
           visible="false" />

</VBox>
