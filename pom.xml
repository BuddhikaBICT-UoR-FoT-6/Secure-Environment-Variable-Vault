<?xml version="1.0" encoding="UTF-8"?>
<!--
    pom.xml — Maven Project Object Model
    ─────────────────────────────────────
    Think of this file as the "blueprint" for your project:
      • It tells Maven what language version to use
      • What external libraries (dependencies) to download
      • How to compile and run the application

    Maven reads this file to automate building your project.
    Run:  mvn javafx:run   → launches the app
          mvn test          → runs JUnit 5 tests
          mvn package       → creates a runnable JAR
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <!-- modelVersion: Always 4.0.0 for modern Maven projects. Don't change this. -->
    <modelVersion>4.0.0</modelVersion>

    <!-- ───────────────────────────────────────────────────────────
         G R O U P   I D
         Like a Java package name for your whole organisation/project.
         Convention: reverse domain notation.
         com.vault = "the vault app I am building"
    ─────────────────────────────────────────────────────────── -->
    <groupId>com.vault</groupId>

    <!-- ───────────────────────────────────────────────────────────
         A R T I F A C T   I D
         The unique name of THIS particular project/module.
         This becomes the name of the generated JAR file.
    ─────────────────────────────────────────────────────────── -->
    <artifactId>env-vault</artifactId>

    <!-- version: Your app version. SNAPSHOT means "work in progress". -->
    <version>1.0-SNAPSHOT</version>

    <!-- packaging: "jar" = compile to a standard Java archive file. -->
    <packaging>jar</packaging>

    <!-- Human-readable name (appears in build logs) -->
    <name>Local Environment Variable Vault</name>

    <!-- ═══════════════════════════════════════════════════════════
         P R O P E R T I E S   (project-wide variables)
         Define values once, reference them everywhere as ${name}.
    ═══════════════════════════════════════════════════════════ -->
    <properties>
        <!-- Tell Maven: use Java 21 language syntax when compiling -->
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>

        <!-- Prevents garbled characters in build output on Windows -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- Central version pins — change version in ONE place and it
             updates all references below automatically -->
        <javafx.version>21.0.2</javafx.version>
        <sqlite.version>3.45.1.0</sqlite.version>
        <gson.version>2.10.1</gson.version>
        <junit.version>5.10.2</junit.version>
    </properties>

    <!-- ═══════════════════════════════════════════════════════════
         D E P E N D E N C I E S
         External libraries Maven downloads from the internet (Maven
         Central Repository) and puts on the classpath automatically.
    ═══════════════════════════════════════════════════════════ -->
    <dependencies>

        <!-- ── 1. JavaFX CONTROLS ──────────────────────────────────
             Provides all the UI widgets:
             Button, TextField, ListView, TableView, PasswordField, etc.
             Without this, you cannot build any JavaFX window.            -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- ── 2. JavaFX FXML ─────────────────────────────────────
             Allows you to load UI layouts from .fxml XML files instead
             of writing every button/label in pure Java code.
             FXML separates "what the UI looks like" from "what it does". -->
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>${javafx.version}</version>
        </dependency>

        <!-- ── 3. SQLite JDBC Driver ──────────────────────────────
             SQLite is a self-contained, serverless database engine that
             stores everything in ONE file (vault.db).
             JDBC (Java Database Connectivity) is the standard Java API
             for talking to any relational database.
             This driver is the bridge between Java and SQLite.           -->
        <dependency>
            <groupId>org.xerial</groupId>
            <artifactId>sqlite-jdbc</artifactId>
            <version>${sqlite.version}</version>
        </dependency>

        <!-- ── 4. Gson (Google JSON library) ──────────────────────
             Converts Java objects ↔ JSON strings.
             Used for any lightweight config serialisation needs.         -->
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>${gson.version}</version>
        </dependency>

        <!-- ── 5. JUnit 5 (Jupiter) ───────────────────────────────
             The modern Java unit testing framework.
             scope=test means this library is ONLY available during
             testing; it is NOT bundled into your final application JAR. -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <!-- ═══════════════════════════════════════════════════════════
         B U I L D   P L U G I N S
         Plugins extend Maven's ability to do things beyond basic
         compile → test → package.
    ═══════════════════════════════════════════════════════════ -->
    <build>
        <plugins>

            <!-- ── Maven Compiler Plugin ──────────────────────────
                 Tells the Java compiler to use Java 17 features.
                 The <release> tag is the modern, single flag that
                 replaces both source AND target together.               -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.12.1</version>
                <configuration>
                    <release>17</release>
                </configuration>
            </plugin>

            <!-- ── JavaFX Maven Plugin ────────────────────────────
                 Adds the command:  mvn javafx:run
                 JavaFX requires special JVM module arguments (--add-opens).
                 This plugin handles all of that automatically.
                 mainClass: the fully-qualified name of your App entry point. -->
            <plugin>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-maven-plugin</artifactId>
                <version>0.0.8</version>
                <configuration>
                    <mainClass>com.vault.App</mainClass>
                </configuration>
            </plugin>

            <!-- ── Maven Surefire Plugin ──────────────────────────
                 Runs your JUnit 5 tests when you execute:  mvn test
                 Version 3.x is required for JUnit 5 (Jupiter) support. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
            </plugin>

        </plugins>
    </build>

</project>
